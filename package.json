{
  "name": "croupier-js-sdk",
  "version": "0.1.0",
  "description": "Croupier Node.js SDK for Game Function Registration with TCP Transport",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "croupier",
    "tcp",
    "transport"
  ],
  "author": "Croupier Team <dev@croupier.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuihairu/croupier-sdk-js.git"
  },
  "homepage": "https://github.com/cuihairu/croupier-sdk-js#readme",
  "bugs": {
    "url": "https://github.com/cuihairu/croupier-sdk-js/issues"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=7.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ examples/ --ext .ts,.js",
    "lint:fix": "eslint src/ examples/ --ext .ts,.js --fix",
    "format": "prettier --write 'src/**/*.ts' 'examples/**/*.js'",
    "format:check": "prettier --check src/**/*.ts examples/**/*.js",
    "dev": "ts-node-dev --respawn examples/main.ts",
    "start": "node dist/examples/main.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@rustup/tcp": "^0.1.2",
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^9.39.2",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-plugin-import": "^2.28.1",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.2.2"
  },
  "files": [
    "dist/",
    "src/",
    "examples/",
    "README.md",
    "LICENSE",
    "package.json"
  ]
}
